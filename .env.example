# Twitch API
# 必填。到 Twitch Developer Console 建立 App 後填入。
TWITCH_CLIENT_ID=

# 建議填寫。服務會用 Client Credentials flow 自動取得與更新 App Access Token。
TWITCH_CLIENT_SECRET=

# 選填。只在沒有 TWITCH_CLIENT_SECRET 時作為手動 token 備援。
TWITCH_ACCESS_TOKEN=

# Telegram Bot
# 預設關閉。啟用時 TELEGRAM_BOT_TOKEN 與 TELEGRAM_ALLOWED_CHAT_IDS 都必填。
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# 本機開發覆寫
# Docker Compose 已固定使用 /app/config.yml；本機執行時可改成 ./config.yml。
# CONFIG_PATH=./config.yml

# 選填。覆寫 config.yml 內的 headless 與 log_level。
# HEADLESS=true
# LOG_LEVEL=info
